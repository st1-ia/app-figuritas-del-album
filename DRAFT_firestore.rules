rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'ownedStickers', 'updatedAt']) 
          && data.keys().size() == 3
          && data.userId is string && data.userId.size() <= 128
          && data.userId == request.auth.uid
          && data.ownedStickers is list
          && data.ownedStickers.size() <= 1000
          && (data.ownedStickers.size() == 0 || data.ownedStickers[0] is string)
          && data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid
                    && isValidUserProfile(incoming());
      allow update: if isSignedIn() && isValidId(userId) && userId == request.auth.uid
                    && isValidUserProfile(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['ownedStickers', 'updatedAt'])
                    && incoming().userId == existing().userId;
    }
  }
}
