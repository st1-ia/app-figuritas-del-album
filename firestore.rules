rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidAlbum(data) {
      return data.ownedStickers is list
          && data.ownedStickers.size() <= 1500
          && (data.ownedStickers.size() == 0 || (data.ownedStickers[0] is string && data.ownedStickers[0].size() <= 64))
          && data.repeatedStickers is list
          && data.repeatedStickers.size() <= 1500
          && (data.repeatedStickers.size() == 0 || (data.repeatedStickers[0] is string && data.repeatedStickers[0].size() <= 64))
          && (!('activities' in data) || (data.activities is list
             && data.activities.size() <= 500
             && (data.activities.size() == 0 || (data.activities[0] is map && data.activities[0].id is string && data.activities[0].text is string && data.activities[0].timestamp is number))))
          && data.updatedAt == request.time;
    }

    // --- Collections ---

    match /albums/global {
      allow get: if true;
      allow create: if incoming().keys().hasAll(['ownedStickers', 'repeatedStickers', 'updatedAt']) 
                    && isValidAlbum(incoming());
      allow update: if isValidAlbum(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['ownedStickers', 'repeatedStickers', 'activities', 'updatedAt']);
    }

    // Connectivity test
    match /test/connection {
      allow read: if true;
    }
  }
}
