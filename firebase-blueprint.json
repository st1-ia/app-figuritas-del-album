{
  "entities": {
    "GlobalAlbum": {
      "title": "GlobalAlbum",
      "description": "Stores globally shared stickers",
      "type": "object",
      "properties": {
        "ownedStickers": {
          "type": "array",
          "description": "List of sticker IDs (e.g. ARG-10)",
          "items": { "type": "string" }
        },
        "repeatedStickers": {
          "type": "array",
          "description": "List of repeated sticker IDs (e.g. ARG-10)",
          "items": { "type": "string" }
        },
        "activities": {
          "type": "array",
          "description": "List of recent activity log events",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "timestamp": { "type": "number" }
            },
            "required": ["id", "text", "timestamp"]
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["ownedStickers", "repeatedStickers", "activities", "updatedAt"]
    }
  },
  "firestore": {
    "albums/global": {
      "schema": { "$ref": "GlobalAlbum" },
      "description": "Single global document tracking all owned stickers."
    }
  }
}
